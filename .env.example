# Telegram BotFather token
TELEGRAM_BOT_TOKEN=replace_with_botfather_token

# twitterapi.io API key
TWITTERAPI_IO_KEY=replace_with_twitterapi_io_key

# Protects POST /webhooks/twitterapi. Use same value as query/header secret in webhook config.
WEBHOOK_SECRET=replace_with_random_webhook_secret

DATABASE_URL=postgres://xmonitor:xmonitor@db:5432/xmonitor?sslmode=disable
HTTP_ADDR=:8080
PUBLIC_BASE_URL=https://your-domain.example

# Optional overrides
# TELEGRAM_API_BASE_URL=https://api.telegram.org
# TWITTERAPI_IO_BASE_URL=https://api.twitterapi.io
# TELEGRAM_POLL_TIMEOUT_SECONDS=25
